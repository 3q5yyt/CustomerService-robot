PORT=4173

# PostgreSQL is optional in local development.
# If DATABASE_URL is absent, the app falls back to data/store.json.
# When DATABASE_URL is present, the app creates the businesses table if needed
# and imports data/store.json into PostgreSQL on first empty-database startup.
DATABASE_URL=postgres://customer_robot_app:change_this_password@127.0.0.1:5432/customer_robot

# Set to 1 when your hosted PostgreSQL provider requires TLS.
DATABASE_SSL=0

# Required by /api/admin/*.
# Generate a long random value and keep it outside Git.
ADMIN_API_TOKEN=change_this_admin_token

# Used to sign demo login sessions. Defaults to ADMIN_API_TOKEN when absent.
AUTH_SESSION_SECRET=change_this_session_secret

# DeepSeek can also be provided through ../API KEY.txt.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
